@model AnotherNewsPlatform.MVC.Models.User.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<h2>Register</h2>

<form asp-action="RegisterProcessing" asp-controller="User" method="post">
    <div class="mb-6 row">
        <div class="">
            <label class="form-label" asp-for=@Model.Username>Username</label>
            <input type="text" name="Username" class="form-control" asp-for=@Model.Username />
            <span asp-validation-for=@Model.Username class="text-danger"></span>
        </div>
        <div class="">
            <label class="form-label" asp-for=@Model.Email>Email</label>
            <input type="email"  class="form-control" asp-for=@Model.Email />
            <span asp-validation-for=@Model.Email class="text-danger"></span>
        </div>
        <div class="">
            <label class="form-label" asp-for=@Model.Password>Password</label>
            <input type="password" name="Password" class="form-control" asp-for=@Model.Password />
            <span asp-validation-for=@Model.Password class="text-danger"></span>
            <label class="form-label" asp-for=@Model.ConfirmPassword>Confirm Password</label>
            <input type="password" class="form-control" asp-for=@Model.ConfirmPassword />
            <span asp-validation-for=@Model.ConfirmPassword class="text-danger"></span>
        </div>
    </div>
    <button type="submit" class="btn btn-primary">Register</button>
    <a asp-action="Login" asp-controller="User">Already have an account? Let's login</a>
   
</form>
